# Lead Extractor - API Keys
# Copy this file to .env and add your keys

# Apify - Get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# SerpAPI - Get from https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# Hunter.io - Get from https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_key_here

# Supabase (optional - for cloud dedup)
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
